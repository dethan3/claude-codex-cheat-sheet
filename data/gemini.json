                {
                  "keyHtml": "gemini -r \"&lt;session-id&gt;\"",
                  "descHtml": "按会话 ID 继续历史任务"
                },
                {
                  "keyHtml": "gemini update",
                  "descHtml": "更新到最新版本"
                }
              ]
            }
          ]
