        {
          "className": "section-keyboard",
          "header": "⌨️ 交互与快捷键",
          "groups": [
            {
              "title": "进入方式",
              "rows": [
                {
                  "keyHtml": "gemini",
                  "descHtml": "启动交互式 REPL"
                },
                {
                  "keyHtml": "gemini \"query\"",
                  "descHtml": "带初始问题进入交互模式"
                },
                {
                  "keyHtml": "gemini -p \"query\"",
                  "descHtml": "非交互单次执行"
                },
                {
                  "keyHtml": "gemini -i \"query\"",
                  "descHtml": "先执行，再继续留在交互界面"
                },
                {
                  "keyHtml": "cat file | gemini",
                  "descHtml": "把管道输入交给 Gemini 处理"
                }
              ]
            },
            {
              "title": "会话恢复",
              "rows": [
                {
                  "keyHtml": "gemini -r \"latest\"",
                  "descHtml": "恢复最近一次会话"
                },
